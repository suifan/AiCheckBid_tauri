{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "AiCheckBidNext",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "open": true,
        "confirm": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.aicheckbid.next",
      "targets": "all",
      "resources": [
        "../rules/**/*",
        "../sidecar/DocParserSidecar/bin/**/*",
        "../sidecar/DocParserSidecarNet48/bin/**/*"
      ],
      "icon": [
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "title": "AiCheckBid Next",
        "width": 1200,
        "height": 760,
        "resizable": true
      }
    ]
  }
}
